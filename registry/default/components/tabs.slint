// slintcn Tabs — segmented control (shadcn default style).
//
// A muted-background pill container holds the triggers; the active trigger
// lifts onto a bg-background surface with a subtle shadow. Slint's @children
// is a single slot, so Tabs is the nav strip only — drive content from
// `current`:
//
//   in-out property <int> active-tab: 0;
//   HorizontalLayout {            // size Tabs to its content, not full width
//       alignment: start;
//       Tabs {
//           items: [{ label: "Account" }, { label: "Password" }];
//           current <=> active-tab;
//       }
//   }
//   if active-tab == 0: VerticalLayout { /* Account content */ }
//
// Keyboard: Tab focuses the strip; ← / → cycle the active tab (wrap-around).

import { Tokens } from "../theme/tokens.slint";

export struct TabItem { label: string }

export component Tabs inherits Rectangle {
    in property <[TabItem]> items;
    in-out property <int> current: 0;
    callback changed(int);

    // TabsList container: bg-muted, rounded-lg, p-1.
    background: Tokens.color-muted;
    border-radius: Tokens.radius-lg;
    height: 36px;

    forward-focus: nav;
    nav := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.LeftArrow) {
                if (root.items.length > 0) {
                    root.current = mod(root.current + root.items.length - 1, root.items.length);
                    root.changed(root.current);
                }
                return accept;
            }
            if (event.text == Key.RightArrow) {
                if (root.items.length > 0) {
                    root.current = mod(root.current + 1, root.items.length);
                    root.changed(root.current);
                }
                return accept;
            }
            return reject;
        }
    }

    HorizontalLayout {
        padding: 4px;    // p-1
        spacing: 4px;

        for item[idx] in items: Rectangle {
            property <bool> active: idx == root.current;

            // Active trigger lifts onto a bg-background surface (shadow-sm);
            // inactive is transparent with a faint hover wash.
            background: active
                ? Tokens.color-background
                : (touch.has-hover ? Tokens.color-surface-1 : transparent);
            border-radius: Tokens.radius-md;

            drop-shadow-blur:     active ? Tokens.shadow-e2-blur     : 0px;
            drop-shadow-offset-y: active ? 1px                       : 0px;
            drop-shadow-color:    active ? Tokens.shadow-e2-color    : transparent;

            min-width: label-text.preferred-width + 24px;   // px-3 each side

            label-text := Text {
                x: (parent.width  - self.preferred-width)  / 2;
                y: (parent.height - self.preferred-height) / 2;
                text: item.label;
                color: active
                    ? Tokens.color-foreground
                    : Tokens.color-muted-foreground;
                font-size: Tokens.typography-body-size;
                font-weight: Tokens.typography-weight-medium;
            }

            touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.current = idx;
                    root.changed(idx);
                    nav.focus();
                }
            }

            animate background, drop-shadow-blur {
                duration: Tokens.motion-fast;
                easing: Tokens.motion-easing-standard;
            }
        }
    }

    // Focus ring around the whole strip while it has keyboard focus.
    if nav.has-focus: Rectangle {
        x: -Tokens.focus-ring-offset;
        y: -Tokens.focus-ring-offset;
        width:  parent.width  + 2 * Tokens.focus-ring-offset;
        height: parent.height + 2 * Tokens.focus-ring-offset;
        border-width: Tokens.focus-ring-width;
        border-color: Tokens.color-ring-muted;
        border-radius: Tokens.radius-lg + Tokens.focus-ring-offset;
        background: transparent;
    }
}
