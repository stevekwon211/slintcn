// slintcn Dialog — modal overlay (Scrim + card panel), shadcn chrome.
//
// Mount as the LAST child of Window (see popup-helpers.slint) sized to the
// full window via `width: parent.width; height: parent.height`.
//
// Public API:
//   in-out property <bool> open
//   in property <string> title / description
//   in property <bool> dismiss-on-backdrop: true
//   in property <string> close-label: "Close"
//   callback dismissed()
//
// Body content goes via `@children` between header and footer.
//
// Interaction: backdrop click closes (when dismiss-on-backdrop); clicks
// INSIDE the panel are absorbed by a panel-wide TouchArea so they never fall
// through to the Scrim. X button (top-right) and Escape also close.

import { Tokens } from "../theme/tokens.slint";
import { Scrim } from "popup-helpers.slint";
import { Button, ButtonVariant } from "button.slint";
import { Separator, SeparatorOrientation } from "separator.slint";
import { Icon } from "icon.slint";
import { LucidePaths } from "lucide-paths.slint";

export component Dialog inherits Rectangle {
    in-out property <bool> open: false;
    in property <string> title;
    in property <string> description;
    in property <bool>   dismiss-on-backdrop: true;
    in property <string> close-label: "Close";
    callback dismissed();

    background: transparent;

    Scrim {
        x: 0; y: 0;
        width:  root.width;
        height: root.height;
        shown: root.open;
        clicked => {
            if (root.dismiss-on-backdrop) {
                root.open = false;
                root.dismissed();
            }
        }
    }

    panel := Rectangle {
        background: Tokens.color-card;
        border-color: Tokens.color-border-hairline;
        border-width: 1px;
        border-radius: Tokens.radius-lg;     // shadcn dialog rounded-lg (10)
        drop-shadow-blur:     Tokens.shadow-e3-blur;
        drop-shadow-offset-y: Tokens.shadow-e3-offset-y;
        drop-shadow-color:    Tokens.shadow-e3-color;

        width: 420px;
        height: layout.preferred-height;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;

        // shadcn fades + zooms; Slint has no scale transform on Rectangle,
        // so we use a clean opacity fade (no floaty slide).
        opacity: root.open ? 1.0 : 0.0;
        visible: root.open || self.opacity > 0.0;
        animate opacity {
            duration: Tokens.motion-base;
            easing: Tokens.motion-easing-standard;
        }

        // Wrap content in a TouchArea so clicks on empty panel area are
        // absorbed (clicked no-op) — they don't fall through to the Scrim
        // behind. Nested controls (the footer Button, body inputs) still
        // receive their own clicks via Slint's nested-TouchArea routing.
        TouchArea {
            clicked => { }

            layout := VerticalLayout {
                padding: Tokens.spacing-xl;       // p-6 (24)
                spacing: Tokens.spacing-lg;       // gap-4 (16)

                // Header
                VerticalLayout {
                    spacing: Tokens.spacing-sm;   // gap-2 (8)
                    if root.title != "": Text {
                        text: root.title;
                        color: Tokens.color-foreground;
                        font-size: Tokens.typography-title-size;
                        font-weight: Tokens.typography-weight-semibold;
                    }
                    if root.description != "": Text {
                        text: root.description;
                        color: Tokens.color-muted-foreground;
                        font-size: Tokens.typography-body-size;
                        wrap: word-wrap;
                    }
                }

                @children

                Separator { orientation: SeparatorOrientation.horizontal; }

                HorizontalLayout {
                    alignment: end;
                    Button {
                        variant: ButtonVariant.default;
                        text: root.close-label;
                        clicked => {
                            root.open = false;
                            root.dismissed();
                        }
                    }
                }
            }
        }

        // X close button, top-right (shadcn).
        close-x := Rectangle {
            x: parent.width - self.width - 12px;
            y: 12px;
            width: 28px;
            height: 28px;
            border-radius: Tokens.radius-sm;
            background: x-touch.has-hover ? Tokens.color-accent : transparent;
            Icon {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                commands: LucidePaths.x-mark;
                tint: Tokens.color-muted-foreground;
                size: 16px;
            }
            x-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.open = false;
                    root.dismissed();
                }
            }
            animate background {
                duration: Tokens.motion-fast;
                easing: Tokens.motion-easing-standard;
            }
        }
    }

    changed open => {
        if (self.open) {
            focus-scope.focus();
        }
    }

    forward-focus: focus-scope;
    focus-scope := FocusScope {
        enabled: root.open;
        key-pressed(event) => {
            if (event.text == "\u{1b}") {
                root.open = false;
                root.dismissed();
                return accept;
            }
            if (event.text == "\u{9}") {
                return accept;   // trap Tab (single focusable footer button)
            }
            return reject;
        }
    }
}
