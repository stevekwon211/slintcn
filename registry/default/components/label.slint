import { Tokens } from "../theme/tokens.slint";

export enum LabelVariant { default, muted, required }

// Form label. Wire `clicked` to focus the associated input — shadcn's
// htmlFor=… without DOM IDs.
//
//   Label { text: "Email"; clicked => { email-input.focus(); } }
//   Input { email-input := ... }
//
// The `required` variant appends a destructive-colored asterisk.
export component Label inherits Rectangle {
    in property <string> text;
    in property <LabelVariant> variant: LabelVariant.default;
    callback clicked();

    background: transparent;
    width:  row.preferred-width;
    height: row.preferred-height;

    row := HorizontalLayout {
        spacing: 2px;
        Text {
            text: root.text;
            color: variant == LabelVariant.muted
                ? Tokens.color-muted-foreground
                : Tokens.color-foreground;
            font-size: Tokens.typography-label-size;
            font-weight: Tokens.typography-weight-medium;
        }
        if variant == LabelVariant.required: Text {
            text: "*";
            color: Tokens.color-destructive;
            font-size: Tokens.typography-label-size;
            font-weight: Tokens.typography-weight-medium;
        }
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}
