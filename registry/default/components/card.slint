import { Tokens } from "../theme/tokens.slint";

// Card is intentionally non-focusable (matches shadcn's <div>-based Card).
// To make a card keyboard-activatable, wrap it in a Button(variant: ghost)
// or place a Button inside it as the affordance.
//
// glass: non-interactive translucent surface (e.g. inside a Dialog body).
// glass-interactive: clickable variant — its border/background respond to hover.
// Both share the same e3 shadow.
export enum CardVariant { solid, glass, glass-interactive, raised }
export enum CardSize    { sm, default }

export component Card inherits Rectangle {
    in property <CardVariant> variant: CardVariant.solid;
    in property <CardSize>    size:    CardSize.default;

    // Read-only hover signal — driven by the internal TouchArea below.
    // Consumers can read it (e.g. to drive header chip styling) but never set it.
    out property <bool> hovered <=> touch.has-hover;

    background:
        variant == CardVariant.glass || variant == CardVariant.glass-interactive ?
            (variant == CardVariant.glass-interactive && hovered
                ? Tokens.color-surface-3
                : Tokens.color-scrim-2) :
        Tokens.color-card;

    border-color:
        variant == CardVariant.glass-interactive && hovered
            ? Tokens.color-border-hairline-strong
            : Tokens.color-border-hairline;
    border-width: 1px;
    border-radius: Tokens.radius-xl;

    drop-shadow-blur:
        variant == CardVariant.glass || variant == CardVariant.glass-interactive
            ? Tokens.shadow-e3-blur :
        variant == CardVariant.raised ? Tokens.shadow-e2-blur : 0px;
    drop-shadow-offset-y:
        variant == CardVariant.glass || variant == CardVariant.glass-interactive
            ? Tokens.shadow-e3-offset-y :
        variant == CardVariant.raised ? Tokens.shadow-e2-offset-y : 0px;
    drop-shadow-color:
        variant == CardVariant.glass || variant == CardVariant.glass-interactive
            ? Tokens.shadow-e3-color :
        variant == CardVariant.raised ? Tokens.shadow-e2-color : transparent;

    animate background, border-color {
        duration: Tokens.motion-base;
        easing: Tokens.motion-easing-standard;
    }

    // shadcn Card: p-6 (24px) padding. gap-l is the in-content rhythm —
    // 16px (gap-4) reads right for mixed form/section content (gap-6 was
    // too airy between form fields). Compact size tightens to 12px.
    out property <length> padding-l:
        size == CardSize.sm ? Tokens.spacing-lg : Tokens.spacing-xl;
    out property <length> gap-l:
        size == CardSize.sm ? Tokens.spacing-md : Tokens.spacing-lg;

    // Hover tracker. Placed before @children so child interactive controls
    // (Buttons, Inputs) sit z-above and receive their own click events.
    touch := TouchArea { }

    @children
}

// shadcn-faithful Card composition helpers. Compose inside a Card's
// VerticalLayout (padding: parent.padding-l; spacing: parent.gap-l):
//
//   Card {
//       VerticalLayout {
//           padding: parent.padding-l;
//           spacing: parent.gap-l;
//           CardHeader {
//               CardTitle { text: "Notifications"; }
//               CardDescription { text: "Choose what to be notified about."; }
//           }
//           // ...content...
//           CardFooter { Button { text: "Save"; } }
//       }
//   }

export component CardTitle inherits Text {
    color: Tokens.color-foreground;
    font-size: Tokens.typography-title-size;   // text-lg (18)
    font-weight: Tokens.typography-weight-semibold;
}

export component CardDescription inherits Text {
    color: Tokens.color-muted-foreground;
    font-size: Tokens.typography-body-size;     // text-sm (14)
    wrap: word-wrap;
}

export component CardHeader inherits VerticalLayout {
    spacing: 6px;   // gap-1.5 between title + description
    @children
}

export component CardContent inherits VerticalLayout {
    spacing: Tokens.spacing-md;
    @children
}

export component CardFooter inherits HorizontalLayout {
    alignment: end;
    spacing: Tokens.spacing-sm;   // gap-2 between footer buttons
    @children
}
