import { Tokens } from "../theme/tokens.slint";

export component Badge inherits Rectangle {
    in property <string> variant: "default";
    in property <string> text;

    height: 22px;
    width: label.preferred-width + 16px;
    border-radius: Tokens.radius-sm;

    background:
        variant == "secondary" ? Tokens.color-secondary :
        variant == "outline" ? transparent :
        variant == "destructive" ? Tokens.color-destructive.with-alpha(0.2) :
        Tokens.color-primary;

    border-width: variant == "outline" ? 1px : 0px;
    border-color: Tokens.color-border-hairline;

    label := Text {
        x: (parent.width - self.preferred-width) / 2;
        y: (parent.height - self.preferred-height) / 2;
        text: root.text;
        font-size: Tokens.typography-label-size;
        font-weight: Tokens.typography-weight-medium;
        color:
            variant == "destructive" ? Tokens.color-destructive :
            variant == "outline" ? Tokens.color-foreground :
            variant == "secondary" ? Tokens.color-foreground :
            Tokens.color-primary-foreground;
    }
}
