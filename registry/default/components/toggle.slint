import { Tokens } from "../theme/tokens.slint";

// Two-state pressable button (shadcn Toggle). `pressed` is in-out.
export enum ToggleVariant { default, outline }

export component Toggle inherits Rectangle {
    in property <string> text;
    in-out property <bool> pressed: false;
    in property <ToggleVariant> variant: ToggleVariant.default;
    in property <bool> disabled: false;
    callback toggled(bool);

    height: Tokens.density-button-default;   // h-9
    min-width: label.preferred-width + 24px;  // px-3
    border-radius: Tokens.radius-md;

    background: root.pressed
        ? Tokens.color-accent
        : (touch.has-hover && !root.disabled ? Tokens.color-surface-1 : transparent);
    border-width: variant == ToggleVariant.outline ? 1px : 0px;
    border-color: Tokens.color-border-hairline;
    opacity: root.disabled ? 0.5 : 1.0;

    label := Text {
        x: (parent.width  - self.preferred-width)  / 2;
        y: (parent.height - self.preferred-height) / 2;
        text: root.text;
        color: root.pressed
            ? Tokens.color-foreground
            : Tokens.color-muted-foreground;
        font-size: Tokens.typography-body-size;
        font-weight: Tokens.typography-weight-medium;
    }

    touch := TouchArea {
        mouse-cursor: root.disabled ? default : pointer;
        clicked => {
            if (!root.disabled) {
                root.pressed = !root.pressed;
                root.toggled(root.pressed);
            }
        }
    }

    animate background {
        duration: Tokens.motion-fast;
        easing: Tokens.motion-easing-standard;
    }
}
