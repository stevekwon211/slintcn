// slintcn AlertDialog — destructive-confirmation modal.
//
// Like Dialog, but:
//   - no body slot (the description IS the message)
//   - no backdrop dismissal (user must explicitly Cancel or Confirm)
//   - footer is Cancel + Action buttons (Action defaults to destructive)
//   - Escape fires cancelled()
//
// Mount the same way as Dialog: LAST child of Window, sized via
// `width: parent.width; height: parent.height`.

import { Tokens } from "../theme/tokens.slint";
import { Scrim } from "popup-helpers.slint";
import { Button, ButtonVariant } from "button.slint";
import { Separator, SeparatorOrientation } from "separator.slint";

export component AlertDialog inherits Rectangle {
    in-out property <bool> open: false;
    in property <string> title;
    in property <string> description;
    in property <string> action-label: "Continue";
    in property <string> cancel-label: "Cancel";
    in property <ButtonVariant> action-variant: ButtonVariant.destructive;
    callback confirmed();
    callback cancelled();

    background: transparent;

    Scrim {
        x: 0; y: 0;
        width:  root.width;
        height: root.height;
        shown: root.open;
        // Backdrop click is intentionally a no-op — the user must choose.
    }

    panel := Rectangle {
        background: Tokens.color-card;
        border-color: Tokens.color-border-hairline;
        border-width: 1px;
        border-radius: Tokens.radius-xl;
        drop-shadow-blur:     Tokens.shadow-e3-blur;
        drop-shadow-offset-y: Tokens.shadow-e3-offset-y;
        drop-shadow-color:    Tokens.shadow-e3-color;

        width: 420px;
        height: layout.preferred-height;
        x: (root.width - self.width) / 2;
        y: root.open
            ? (root.height - self.height) / 2
            : (root.height - self.height) / 2 + 8px;

        opacity: root.open ? 1.0 : 0.0;

        animate opacity, y {
            duration: Tokens.motion-base;
            easing: Tokens.motion-easing-standard;
        }

        layout := VerticalLayout {
            padding: Tokens.spacing-lg;
            spacing: Tokens.spacing-md;

            VerticalLayout {
                spacing: 4px;
                if root.title != "": Text {
                    text: root.title;
                    color: Tokens.color-foreground;
                    font-size: 18px;
                    font-weight: Tokens.typography-weight-semibold;
                }
                if root.description != "": Text {
                    text: root.description;
                    color: Tokens.color-muted-foreground;
                    font-size: Tokens.typography-body-size;
                    wrap: word-wrap;
                }
            }

            Separator { orientation: SeparatorOrientation.horizontal; }

            HorizontalLayout {
                alignment: end;
                spacing: Tokens.spacing-sm;
                cancel-btn := Button {
                    variant: ButtonVariant.outline;
                    text: root.cancel-label;
                    clicked => {
                        root.open = false;
                        root.cancelled();
                    }
                }
                action-btn := Button {
                    variant: root.action-variant;
                    text: root.action-label;
                    clicked => {
                        root.open = false;
                        root.confirmed();
                    }
                }
            }
        }
    }

    // Focus trap state: 0 = Cancel (default on open), 1 = Action.
    in-out property <int> trap-index: 0;

    changed open => {
        if (self.open) {
            self.trap-index = 0;
            cancel-btn.focus();
        }
    }

    forward-focus: focus-scope;
    focus-scope := FocusScope {
        enabled: root.open;
        key-pressed(event) => {
            if (event.text == "\u{1b}") {
                root.open = false;
                root.cancelled();
                return accept;
            }
            // Tab / Shift+Tab cycle between Cancel (0) and Action (1).
            // With two focusables the wrap direction is symmetric — both
            // Tab and Shift+Tab just flip the index.
            if (event.text == "\u{9}") {
                root.trap-index = root.trap-index == 0 ? 1 : 0;
                if (root.trap-index == 0) { cancel-btn.focus(); }
                else                       { action-btn.focus(); }
                return accept;
            }
            return reject;
        }
    }
}
