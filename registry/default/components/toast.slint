// slintcn Toast — Sonner-shaped imperative API, growable Rust-backed queue.
//
// Usage (Slint side):
//   import { Toaster, ToastQueue, ToastVariant } from "slintcn/components/toast.slint";
//
//   // Mount once at Window root (last child, like Dialog):
//   Toaster { width: parent.width; height: parent.height; }
//
//   // Fire from anywhere:
//   ToastQueue.show("Saved.", ToastVariant.success);
//
// v0.7 changes the backing model from the v0.4 3-slot ring buffer to a
// real growable Rust slint::VecModel<ToastItem>. The 3-slot was a
// workaround for Slint 1.16's missing array spread / filter; the Rust
// side owns the queue cleanly now.
//
// Rust glue (showcase main.rs ships a reference impl):
//
//   let items: Rc<VecModel<ToastItem>> = Rc::default();
//   ui.global::<ToastQueue>().set_items(ModelRc::from(items.clone()));
//   ui.global::<ToastQueue>().on_show(move |text, variant| {
//       items.push(ToastItem { id, text, variant });
//       // start a Timer that calls invoke_dismiss(id) after 3s
//   });
//   ui.global::<ToastQueue>().on_dismiss(move |id| {
//       items.remove_where(|t| t.id == id);
//   });
//
// Without that glue, show() is a no-op (no handler bound).

import { Tokens } from "../theme/tokens.slint";

export enum ToastVariant { default, success, error }

export struct ToastItem {
    id: int,
    text: string,
    variant: ToastVariant,
}

export global ToastQueue {
    in-out property <[ToastItem]> items: [];
    callback show(string, ToastVariant);
    callback dismiss(int);
}

component ToastView inherits Rectangle {
    in property <ToastItem> item;
    in property <int> stack-index;
    in property <length> available-width;
    in property <length> available-height;

    background:
        item.variant == ToastVariant.success
            ? Tokens.color-primary :
        item.variant == ToastVariant.error
            ? Tokens.color-destructive.with-alpha(0.95) :
            Tokens.color-card;
    border-color: Tokens.color-border-hairline-strong;
    border-width: 1px;
    border-radius: Tokens.radius-md;
    drop-shadow-blur:     Tokens.shadow-e3-blur;
    drop-shadow-offset-y: Tokens.shadow-e3-offset-y;
    drop-shadow-color:    Tokens.shadow-e3-color;

    width:  toast-text.preferred-width + 28px;
    height: 36px;

    // Bottom-right anchored, stacked upward by stack-index. v0.7 ships
    // instant removal — fade-out animation needs a 2-phase Rust dismiss
    // (set `dismissed: true`, animate, then remove from model) — v0.8.
    x: available-width  - self.width  - 16px;
    y: available-height - self.height - 16px - (stack-index * 44px);

    toast-text := Text {
        x: 14px;
        y: (parent.height - self.preferred-height) / 2;
        text: item.text;
        color: item.variant == ToastVariant.success
            ? Tokens.color-primary-foreground
            : Tokens.color-foreground;
        font-size: Tokens.typography-body-size;
        font-weight: Tokens.typography-weight-medium;
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => { ToastQueue.dismiss(item.id); }
    }
}

export component Toaster inherits Rectangle {
    background: transparent;

    for item[idx] in ToastQueue.items: ToastView {
        item: item;
        stack-index: idx;
        available-width:  root.width;
        available-height: root.height;
    }
}
