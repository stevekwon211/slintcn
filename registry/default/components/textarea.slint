import { Tokens } from "../theme/tokens.slint";
import { FocusRing } from "focus-ring.slint";

// Multi-line text input. Like Input but taller and word-wrapping.
export component Textarea inherits Rectangle {
    // Two-way bound to the contents.
    in-out property <string> text;
    // Hint shown when empty.
    in property <string> placeholder;
    // When false, the textarea dims and stops accepting keystrokes.
    in property <bool> enabled: true;
    // Fired on every keystroke with the current text.
    callback edited(string);

    // True while focus arrived from a pointer press — suppresses the ring so it
    // is keyboard-only (focus-visible emulation). Set on pointer down, cleared
    // on any key interaction.
    property <bool> pointer-focus: false;

    forward-focus: field-scope;

    min-height: 72px;
    background: Tokens.color-surface-1;
    border-color: input.has-focus ? Tokens.color-ring : Tokens.color-border-hairline;
    border-width: 1px;
    border-radius: Tokens.radius-md;
    opacity: root.enabled ? 1.0 : 0.5;

    focus-area := TouchArea {
        pointer-event(ev) => {
            if (root.enabled
                    && ev.button == PointerEventButton.left
                    && ev.kind == PointerEventKind.down) {
                root.pointer-focus = true;
            }
        }
        clicked => { input.focus(); }
    }

    field-scope := FocusScope {
        // Zero-size so the scope cannot intercept the first pointer press
        // (default FocusScope fills its parent and swallows that click).
        width: 0px;
        height: 0px;
        enabled: root.enabled;
        forward-focus: input;
        key-pressed(event) => {
            root.pointer-focus = false;
            return reject;
        }
    }

    input := TextInput {
        x: 12px;
        y: 8px;
        width: parent.width - 24px;
        height: parent.height - 16px;
        text <=> root.text;
        color: Tokens.color-foreground;
        font-size: Tokens.typography-body-size;
        wrap: word-wrap;
        single-line: false;
        read-only: !root.enabled;
        edited => { root.edited(self.text); }
    }

    if root.text == "": Text {
        x: 12px;
        y: 8px;
        width: parent.width - 24px;
        text: root.placeholder;
        color: Tokens.color-muted-foreground;
        font-size: Tokens.typography-body-size;
        wrap: word-wrap;
    }

    if input.has-focus && !root.pointer-focus : FocusRing {
        host-width: parent.width;
        host-height: parent.height;
    }
}
