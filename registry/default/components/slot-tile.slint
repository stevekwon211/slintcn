import { Tokens } from "../theme/tokens.slint";

// Inventory / hotbar slot tile. `tone` sets the resting fill, `state` adds a
// selection ring or dims it, and `interactive` enables hover feedback. Place
// the slot's contents (icon, count Badge, Keycap) as @children — they're
// centered in the tile.
export enum SlotTileTone  { stone, empty, accent }
export enum SlotTileState { idle, active, disabled }

export component SlotTile inherits Rectangle {
    // Surface tint — `stone`, `iron`, `gold`, etc.
    in property <SlotTileTone>  tone:  SlotTileTone.stone;
    // Visual state — `idle`, `selected`, `disabled`.
    in property <SlotTileState> state: SlotTileState.idle;
    // When true, the tile shows hover affordances and emits `clicked`.
    in property <bool> interactive: false;
    // Pixel side length of the square tile.
    in property <length> size: 48px;
    // Fired on press release when `interactive` is true.
    callback clicked();

    property <bool> hot: interactive && state != SlotTileState.disabled;

    width:  root.size;
    height: root.size;
    opacity: state == SlotTileState.disabled ? 0.4 : 1.0;

    surface := Rectangle {
        x: 0;
        y: root.hot && touch.pressed ? 1px : 0px;
        width:  parent.width;
        height: parent.height;
        border-radius: Tokens.radius-md;

        background:
            tone == SlotTileTone.empty  ? transparent :
            tone == SlotTileTone.accent ? Tokens.color-primary.with-alpha(0.12) :
            (root.hot && touch.has-hover ? Tokens.color-surface-2 : Tokens.color-surface-1);

        border-width:
            state == SlotTileState.active ? 2px : 1px;
        border-color:
            state == SlotTileState.active ? Tokens.color-primary :
            tone == SlotTileTone.empty    ? Tokens.color-border-hairline :
            tone == SlotTileTone.accent   ? Tokens.color-primary.with-alpha(0.5) :
            Tokens.color-border-hairline-strong;

        @children

        animate y, background, border-color {
            duration: Tokens.motion-fast;
            easing: Tokens.motion-easing-standard;
        }
    }

    touch := TouchArea {
        enabled: root.hot;
        mouse-cursor: root.hot ? pointer : default;
        clicked => { root.clicked(); }
    }
}
