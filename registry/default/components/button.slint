// slintcn Button — copy-paste primitive (you own this file after `slintcn add`).

import { Tokens } from "../theme/tokens.slint";

export enum ButtonVariant {
    default, outline, secondary, ghost, link, destructive, glow, glass,
}

export enum ButtonSize {
    xs, sm, default, lg, icon, icon-xs, icon-sm, icon-lg,
}

export component Button inherits Rectangle {
    in property <ButtonVariant> variant: ButtonVariant.default;
    in property <ButtonSize>    size:    ButtonSize.default;
    in property <string> text;
    in property <bool>   disabled: false;
    callback clicked();

    property <length> hpad:
        size == ButtonSize.xs ? 8px :
        size == ButtonSize.sm ? 10px :
        size == ButtonSize.lg ? 12px : 10px;

    height:
        size == ButtonSize.xs || size == ButtonSize.icon-xs ? Tokens.density-button-xs :
        size == ButtonSize.sm || size == ButtonSize.icon-sm ? Tokens.density-button-sm :
        size == ButtonSize.lg || size == ButtonSize.icon-lg ? Tokens.density-button-lg :
        Tokens.density-button-default;

    width:
        size == ButtonSize.icon || size == ButtonSize.icon-xs
            || size == ButtonSize.icon-sm || size == ButtonSize.icon-lg
                ? self.height
                : label.preferred-width + 2 * hpad;

    border-radius: Tokens.radius-md;

    background:
        variant == ButtonVariant.outline ?
            (touch.has-hover && !disabled
                ? Tokens.color-surface-1.with-alpha(0.5)
                : Tokens.color-surface-1.with-alpha(0.3)) :
        variant == ButtonVariant.ghost ?
            (touch.has-hover && !disabled
                ? Tokens.color-muted.with-alpha(0.5)
                : transparent) :
        variant == ButtonVariant.link ? transparent :
        variant == ButtonVariant.secondary ?
            (touch.has-hover && !disabled
                ? Tokens.color-secondary.with-alpha(0.8)
                : Tokens.color-secondary) :
        variant == ButtonVariant.glass ?
            (touch.has-hover && !disabled ? Tokens.color-surface-3 : Tokens.color-scrim-2) :
        variant == ButtonVariant.destructive ?
            (touch.has-hover && !disabled
                ? Tokens.color-destructive.with-alpha(0.3)
                : Tokens.color-destructive.with-alpha(0.2)) :
            (touch.has-hover && !disabled
                ? Tokens.color-foreground.with-alpha(0.95)
                : Tokens.color-foreground);

    border-width: variant == ButtonVariant.outline || variant == ButtonVariant.glass ? 1px : 0px;
    border-color:
        variant == ButtonVariant.outline || variant == ButtonVariant.glass
            ? (touch.has-hover && !disabled
                ? Tokens.color-border-hairline-strong
                : Tokens.color-border-hairline)
            : transparent;

    drop-shadow-blur:
        variant == ButtonVariant.glow ?
            (touch.has-hover && !disabled
                ? Tokens.shadow-glow-lg-blur
                : Tokens.shadow-glow-md-blur) : 0px;
    drop-shadow-color:
        variant == ButtonVariant.glow ?
            (touch.has-hover && !disabled
                ? Tokens.shadow-glow-lg-color
                : Tokens.shadow-glow-md-color) : transparent;

    y: disabled ? 0px : (touch.pressed ? 1px : 0px);
    opacity: disabled ? 0.5 : 1.0;

    animate y, opacity, background, border-color, drop-shadow-blur {
        duration: Tokens.motion-fast;
        easing: Tokens.motion-easing-standard;
    }

    label := Text {
        x: (parent.width - self.preferred-width) / 2;
        y: (parent.height - self.preferred-height) / 2;
        text: root.text;
        color:
            variant == ButtonVariant.default || variant == ButtonVariant.glow
                ? Tokens.color-primary-foreground :
            variant == ButtonVariant.destructive ? Tokens.color-destructive :
            variant == ButtonVariant.link ? Tokens.color-primary :
            (variant == ButtonVariant.ghost || variant == ButtonVariant.outline)
                ? (touch.has-hover && !disabled
                    ? Tokens.color-foreground
                    : Tokens.color-muted-foreground)
                : Tokens.color-foreground;
        font-size:
            size == ButtonSize.xs || size == ButtonSize.sm
                ? Tokens.typography-body-sm-size
                : Tokens.typography-body-size;
        font-weight: Tokens.typography-weight-medium;
        visible: root.text != "";
    }

    if variant == ButtonVariant.link && touch.has-hover && !disabled: Rectangle {
        x: label.x;
        y: label.y + label.preferred-height - 2px;
        width: label.preferred-width;
        height: 1px;
        background: Tokens.color-primary;
    }

    @children

    touch := TouchArea {
        mouse-cursor: root.disabled ? default : pointer;
        clicked => { if (!root.disabled) { root.clicked(); } }
    }
}
