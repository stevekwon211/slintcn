// slintcn palette — raw color primitives.
//
// This is the internal scale. Components never read from `Palette` directly;
// they go through `Tokens` (the semantic layer in tokens.slint). Edit values
// here to retune the whole theme; edit token names there to remap semantics.
//
// The neutral scale is shadcn / Tailwind-adjacent but slintcn-tuned —
// notably `neutral-400` keeps slintcn's existing #a1a1a1 (slightly cooler
// than Tailwind's #a3a3a3) for stronger contrast on OLED black backgrounds.

export global Palette {
    // neutral scale (cold gray, OLED-aware)
    out property <color> neutral-50:  #fafafa;
    out property <color> neutral-100: #f5f5f5;
    out property <color> neutral-200: #e5e5e5;
    out property <color> neutral-300: #d4d4d4;
    out property <color> neutral-400: #a1a1a1;
    out property <color> neutral-500: #737373;
    out property <color> neutral-600: #525252;
    out property <color> neutral-700: #404040;
    out property <color> neutral-800: #262626;
    out property <color> neutral-900: #171717;
    out property <color> neutral-950: #0a0a0a;

    // accents (only what's currently used; extend as needed)
    out property <color> red-400:   #ff6467;
    out property <color> green-400: #4ade80;

    // alpha primitives — translucent overlays for glass/scrim/hairline work.
    // Named by base color (w = white, b = black) and alpha % × 100.
    out property <color> alpha-w-04: rgba(255, 255, 255, 0.04);
    out property <color> alpha-w-08: rgba(255, 255, 255, 0.08);
    out property <color> alpha-w-10: rgba(255, 255, 255, 0.10);
    out property <color> alpha-w-12: rgba(255, 255, 255, 0.12);
    out property <color> alpha-w-20: rgba(255, 255, 255, 0.20);
    out property <color> alpha-w-25: rgba(255, 255, 255, 0.25);
    out property <color> alpha-w-35: rgba(255, 255, 255, 0.35);
    out property <color> alpha-b-30: rgba(0, 0, 0, 0.30);
    out property <color> alpha-b-32: rgba(0, 0, 0, 0.32);
    out property <color> alpha-b-38: rgba(0, 0, 0, 0.38);
    out property <color> alpha-b-45: rgba(0, 0, 0, 0.45);
    out property <color> alpha-b-60: rgba(0, 0, 0, 0.60);

    // Black-on-light overlays mirror alpha-w-* for the light theme — at these
    // low opacities the visual weight matches white-on-dark closely enough
    // that the same semantic roles (surface-1/2/3, hairline borders) can swap
    // tints without retuning thicknesses.
    out property <color> alpha-b-04-on-light: rgba(0, 0, 0, 0.04);
    out property <color> alpha-b-08-on-light: rgba(0, 0, 0, 0.08);
    out property <color> alpha-b-10-on-light: rgba(0, 0, 0, 0.10);
    out property <color> alpha-b-12-on-light: rgba(0, 0, 0, 0.12);
    out property <color> alpha-b-20-on-light: rgba(0, 0, 0, 0.20);
}
