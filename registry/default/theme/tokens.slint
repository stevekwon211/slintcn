// slintcn default theme — dark + light, switchable at runtime.
//
// `Theme.mode` selects which palette slot each semantic role pulls from.
// Components only read `Tokens.*` — they don't care which mode is active.
// Mutate `Theme.mode = ThemeMode.light` from Rust or Slint anywhere and
// every color binding updates reactively.
//
// To retune a VALUE: edit palette.slint.
// To remap a SEMANTIC ROLE: change the per-mode picks below.

import { Palette } from "palette.slint";

export enum ThemeMode { dark, light }

export global Theme {
    in-out property <ThemeMode> mode: ThemeMode.dark;
}

export global Tokens {
    // surfaces
    out property <color> color-background:
        Theme.mode == ThemeMode.light ? Palette.neutral-50  : Palette.neutral-950;
    out property <color> color-foreground:
        Theme.mode == ThemeMode.light ? Palette.neutral-900 : Palette.neutral-50;
    out property <color> color-card:
        Theme.mode == ThemeMode.light ? Palette.neutral-100 : Palette.neutral-900;
    out property <color> color-card-foreground:
        Theme.mode == ThemeMode.light ? Palette.neutral-900 : Palette.neutral-50;

    // intent
    out property <color> color-primary:
        Theme.mode == ThemeMode.light ? Palette.neutral-900 : Palette.neutral-200;
    out property <color> color-primary-foreground:
        Theme.mode == ThemeMode.light ? Palette.neutral-50  : Palette.neutral-900;
    out property <color> color-secondary:
        Theme.mode == ThemeMode.light ? Palette.neutral-100 : Palette.neutral-800;
    out property <color> color-muted:
        Theme.mode == ThemeMode.light ? Palette.neutral-100 : Palette.neutral-800;
    out property <color> color-muted-foreground:
        Theme.mode == ThemeMode.light ? Palette.neutral-500 : Palette.neutral-400;
    out property <color> color-destructive:        Palette.red-400;

    // focus / interaction
    out property <color> color-ring:
        Theme.mode == ThemeMode.light ? Palette.neutral-700 : Palette.neutral-500;
    out property <length> focus-ring-width:  2px;
    out property <length> focus-ring-offset: 2px;

    // glass / scrim / hairline — overlays invert their tint per mode so the
    // contrast stays comfortable on either background.
    out property <color> color-surface-1:
        Theme.mode == ThemeMode.light ? Palette.alpha-b-04-on-light : Palette.alpha-w-04;
    out property <color> color-surface-2:
        Theme.mode == ThemeMode.light ? Palette.alpha-b-08-on-light : Palette.alpha-w-08;
    out property <color> color-surface-3:
        Theme.mode == ThemeMode.light ? Palette.alpha-b-12-on-light : Palette.alpha-w-12;
    // Scrim is always a dim black wash regardless of mode.
    out property <color> color-scrim-2: Palette.alpha-b-60;
    out property <color> color-border-hairline:
        Theme.mode == ThemeMode.light ? Palette.alpha-b-10-on-light : Palette.alpha-w-10;
    out property <color> color-border-hairline-strong:
        Theme.mode == ThemeMode.light ? Palette.alpha-b-20-on-light : Palette.alpha-w-20;

    // radius
    out property <length> radius-sm: 6px;
    out property <length> radius-md: 8px;
    out property <length> radius-lg: 10px;
    out property <length> radius-xl: 14px;

    // motion
    out property <duration> motion-fast: 150ms;
    out property <duration> motion-base: 200ms;
    out property <easing>   motion-easing-standard:    cubic-bezier(0.2, 0.0, 0.0, 1.0);
    out property <easing>   motion-easing-emphasized:  cubic-bezier(0.05, 0.7, 0.1, 1.0);

    // elevation shadows (same shadow tone for both themes — natural)
    out property <length> shadow-e2-blur:     8px;
    out property <length> shadow-e2-offset-y: 2px;
    out property <color>  shadow-e2-color:    Palette.alpha-b-32;
    out property <length> shadow-e3-blur:     24px;
    out property <length> shadow-e3-offset-y: 8px;
    out property <color>  shadow-e3-color:    Palette.alpha-b-38;

    // glow effects (subtler tint in light mode)
    out property <length> shadow-glow-md-blur:  16px;
    out property <color>  shadow-glow-md-color:
        Theme.mode == ThemeMode.light ? Palette.alpha-b-20-on-light : Palette.alpha-w-25;
    out property <length> shadow-glow-lg-blur:  24px;
    out property <color>  shadow-glow-lg-color:
        Theme.mode == ThemeMode.light ? Palette.alpha-b-32 : Palette.alpha-w-35;

    // typography
    out property <int>    typography-weight-medium:     500;
    out property <int>    typography-weight-semibold:   600;
    out property <length> typography-body-sm-size:      13px;
    out property <length> typography-body-size:         14px;
    out property <length> typography-label-size:        12px;

    // spacing
    out property <length> spacing-xs: 4px;
    out property <length> spacing-sm: 8px;
    out property <length> spacing-md: 12px;
    out property <length> spacing-lg: 16px;

    // control density (button heights)
    out property <length> density-button-xs:      24px;
    out property <length> density-button-sm:      28px;
    out property <length> density-button-default: 32px;
    out property <length> density-button-lg:      40px;
}
