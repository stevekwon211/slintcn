import { Tokens } from "../../../registry/default/theme/tokens.slint";
import { Button, ButtonVariant, ButtonSize } from "../../../registry/default/components/button.slint";
import { Card, CardVariant } from "../../../registry/default/components/card.slint";
import { Input } from "../../../registry/default/components/input.slint";
import { Badge, BadgeVariant } from "../../../registry/default/components/badge.slint";

export component AppWindow inherits Window {
    title: "slintcn showcase";
    preferred-width: 720px;
    preferred-height: 640px;
    background: Tokens.color-background;

    VerticalLayout {
        padding: 24px;
        spacing: 20px;

        HorizontalLayout {
            spacing: 8px;
            Badge { text: "slintcn"; variant: BadgeVariant.default; }
            Badge { text: "v0.1"; variant: BadgeVariant.secondary; }
            Badge { text: "dark glass"; variant: BadgeVariant.outline; }
        }

        Text {
            text: "Buttons";
            color: Tokens.color-muted-foreground;
            font-size: Tokens.typography-label-size;
        }

        HorizontalLayout {
            spacing: 8px;
            Button { variant: ButtonVariant.default;   text: "Default"; }
            Button { variant: ButtonVariant.secondary; text: "Secondary"; }
            Button { variant: ButtonVariant.outline;   text: "Outline"; }
            Button { variant: ButtonVariant.ghost;     text: "Ghost"; }
        }

        HorizontalLayout {
            spacing: 8px;
            Button { variant: ButtonVariant.glass;       text: "Glass"; }
            Button { variant: ButtonVariant.glow;        text: "Glow CTA"; size: ButtonSize.lg; }
            Button { variant: ButtonVariant.destructive; text: "Delete"; }
            Button { variant: ButtonVariant.link;        text: "Learn more"; }
        }

        Text {
            text: "Card + Input";
            color: Tokens.color-muted-foreground;
            font-size: Tokens.typography-label-size;
        }

        Card {
            variant: CardVariant.glass;
            width: 100%;
            height: 140px;

            VerticalLayout {
                padding: parent.padding-l;
                spacing: parent.gap-l;

                Text {
                    text: "Glass card on dark background";
                    color: Tokens.color-foreground;
                    font-weight: Tokens.typography-weight-semibold;
                }

                Input {
                    width: 100%;
                    placeholder: "Type here…";
                }
            }
        }
    }
}
